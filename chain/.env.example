RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
CHAIN_ID=11155111
USDC_TOKEN_ADDRESS=
USDT_TOKEN_ADDRESS=

# Use a dedicated Sepolia deployer / liquidity-provider key.
DEPLOYER_PRIVATE_KEY=

# Escrow deploy defaults.
# VERIFIER_ADDRESS=

# Mock stable deploy defaults.
# INITIAL_STABLE_LIQUIDITY_RECIPIENT=
# INITIAL_USDC_MINT=2500000000000
# INITIAL_USDT_MINT=2500000000000

# Official Uniswap V2 Sepolia deployments from Uniswap docs:
# Factory: 0xF62c03E08ada871A0bEb309762E260a7a6a880E6
# Router:  0xeE567Fe1712Faf6149d80dA1E6934E354124CfE3
UNISWAP_V2_FACTORY_ADDRESS=0xF62c03E08ada871A0bEb309762E260a7a6a880E6
UNISWAP_V2_ROUTER_ADDRESS=0xeE567Fe1712Faf6149d80dA1E6934E354124CfE3

# Pool seeding defaults: 250k / 250k of 6-decimal mocks.
UNISWAP_LIQUIDITY_USDC=250000000000
UNISWAP_LIQUIDITY_USDT=250000000000
# UNISWAP_LP_RECIPIENT=

# Optional local mint file used by existing dev tooling.
MINTS_FILE=mint.mock-usdc.json

# Used by DeployEthyAdsOffchainResolver.s.sol.
ENS_CCIP_GATEWAY_URL=http://localhost:3001/api/ens/ccip-read/{sender}/{data}.json

# Only needed for verified Sepolia deployments.
ETHERSCAN_API_KEY=
