RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337
USDC_TOKEN_ADDRESS=

# Use an Anvil private key locally. Use a dedicated deployer key for Sepolia.
DEPLOYER_PRIVATE_KEY=

# Local deploy defaults to the deployer address when omitted.
# VERIFIER_ADDRESS=

# Optional local/mock token mint settings.
# INITIAL_USDC_RECIPIENT=
# INITIAL_USDC_MINT=1000000000000
MINTS_FILE=mint.mock-usdc.json

# Used by DeployEthyAdsOffchainResolver.s.sol.
ENS_CCIP_GATEWAY_URL=http://localhost:3001/api/ens/ccip-read/{sender}/{data}.json

# Only needed for verified Sepolia deployments.
ETHERSCAN_API_KEY=
