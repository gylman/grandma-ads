  "scripts": {
    "build": "forge build",
    "deploy:local": "forge script script/DeployLocal.s.sol:DeployLocal --rpc-url ${RPC_URL:-http://127.0.0.1:8545} --broadcast",
    "deploy:mock-usdc": "forge script script/DeployMockUSDC.s.sol:DeployMockUSDC --rpc-url ${RPC_URL:-http://127.0.0.1:8545} --broadcast",
    "deploy:sepolia": "forge script script/DeploySepoliaEscrow.s.sol:DeploySepoliaEscrow --rpc-url $RPC_URL --broadcast --verify",
    "fmt": "forge fmt",
    "test": "forge test --offline"
  }
}
